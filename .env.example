# AI API Key: used only by the local/backend server.
# Create .env.local and put your real key there. Do not commit .env.local.
AI_API_KEY="MY_AI_API_KEY"
AI_BASE_URL="https://api.deepseek.com"
AI_MODEL="deepseek-v4-flash"
# Optional local/Vercel timeout override in milliseconds. Default is 20000.
AI_TIMEOUT_MS="20000"

# Legacy DeepSeek names are still supported for compatibility.
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# DeepSeek official OpenAI-compatible endpoint.
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# Default cheap/fast model. You can switch to deepseek-v4-pro if needed.
DEEPSEEK_MODEL="deepseek-v4-flash"

# Local API server port. Vite proxies /api to this port in development.
API_PORT="8787"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
