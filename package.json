{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-with-api.mjs",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "tsx apps/api/src/index.ts",
    "check:api": "tsc --noEmit -p apps/api/tsconfig.json",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:compatibility": "tsx scripts/test-tank-compatibility-engine.ts",
    "test:favorites": "tsx scripts/test-favorites-service.ts",
    "test:taxonomy": "tsx scripts/assert_taxonomy_rules.ts",
    "test:species-knowledge": "tsx scripts/assert_species_detail_knowledge.ts",
    "test:ai-entry-policy": "tsx scripts/assert_ai_entry_policy.ts",
    "test:copilot-contract": "tsx scripts/assert_tank_copilot_contract.ts",
    "test:copilot-evaluation": "tsx scripts/evaluate_tank_copilot.ts",
    "test:3d-assets": "tsx scripts/assert_3d_species_assets.ts",
    "test:layout-mode": "tsx scripts/assert_layout_mode_policy.ts",
    "test:mini-compatibility": "tsx scripts/test-mini-compatibility.ts",
    "test:daily-check": "tsx scripts/test-daily-check-contract.ts",
    "test:session-events": "tsx scripts/test-session-events.ts",
    "test:collection": "tsx scripts/test-collection-achievements.ts",
    "test:memorial": "tsx scripts/test-memorial-service.ts",
    "test:state-services": "tsx scripts/test-business-state-services.ts",
    "test:product-actions": "tsx scripts/audit-product-actions.ts",
    "test:responsive-images": "python3 scripts/test_responsive_images.py",
    "test:three-step-paths": "tsx scripts/test-three-step-paths.ts",
    "test:three-step-ui": "node scripts/verify-three-step-experience.mjs",
    "test:core-ui": "node scripts/verify-core-experience.mjs",
    "test:mobile-care-ui": "node scripts/verify-mobile-care-experience.mjs",
    "test:wishlist-shortcut-ui": "node scripts/verify-wishlist-shortcut.mjs",
    "test:three-tier-contract": "node --import tsx scripts/test-three-tier-contract.ts",
    "test:api-boundary": "node --import tsx scripts/test-api-boundary.ts",
    "audit:images": "python3 scripts/audit_species_images.py",
    "audit:taxonomy": "tsx scripts/generate_taxonomy_review.ts",
    "audit:species-knowledge": "python3 scripts/audit_species_knowledge.py",
    "refresh:species-assets": "python3 scripts/prepare_species_assets_and_data.py && python3 scripts/add_housing_profiles.py && python3 scripts/add_feeding_profiles_to_fish_data.py && python3 scripts/audit_species_images.py"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
